# ============================================================
# Kairos Assistant - Variaveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ============================================================

# --- LLM (OpenRouter) ---
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=openrouter/auto

# --- Banco de Dados ---
# Producao: PostgreSQL
DATABASE_URL=postgresql+asyncpg://kairos:kairos2026@localhost:5432/kairos_assistant
# Desenvolvimento: SQLite (descomente para usar)
# DATABASE_URL=sqlite+aiosqlite:///./kairos_dev.db

# --- Seguranca ---
JWT_SECRET=change-this-to-a-random-secret-in-production
DEBUG=false

# --- Aion Engine ---
AION_BASE_URL=http://localhost:8080
AION_API_KEY=

# --- Ollama (LLM local para agentes - sem custo) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# --- Sistema de Agentes LangGraph ---
LANGGRAPH_ENABLED=true
DEFAULT_AGENT_APP=geral

# --- Audio/TTS ---
TTS_API_KEY=
TTS_PROVIDER=elevenlabs

# --- PostgreSQL (para docker-compose) ---
POSTGRES_PASSWORD=kairos2026
POSTGRES_DB=kairos_assistant
POSTGRES_USER=kairos

# --- Frontend ---
API_KEY=kairos-local-key
NEXT_PUBLIC_API_URL=http://localhost:8070

# --- Dominio de Producao ---
# Frontend: https://kairos-assistant.fbautomacao.space
# Backend API: https://api.kairos-assistant.fbautomacao.space
